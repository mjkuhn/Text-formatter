EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
 G:tival = max((G:rmval+G:tival-fwidth(buf)) / 2, 0)
[END]
[END]
[PROCEDURE]
NAME getstrn
PROTOTYPE '(*STRING,*STRING,*LONG)'
PARAMETERS '(buf, arg, i)'
NOEXPORT
[COMMON]
DESCRIPTION 'gets the string argument on command line'
FROM Clarion Source
MODIFIED '2026/06/14' '10:47:48'
[DATA]
[SCREENCONTROLS]
! PROMPT('argtype:'),USE(?argtype:Prompt)
! ENTRY(@s1),USE(argtype)
[REPORTCONTROLS]
! STRING(@s1),USE(argtype)
argtype                  STRING(1)
!!> GUID('1a38eeb5-406e-4b5f-ba9c-1efc86a953ff'),PROMPT('argtype:'),HEADER('argtype'),PICTURE(@s1)
[SCREENCONTROLS]
! PROMPT('quoted:'),USE(?quoted:Prompt)
! ENTRY(@n3),USE(quoted)
[REPORTCONTROLS]
! STRING(@n3),USE(quoted)
quoted                   BYTE
!!> GUID('548d8bf5-7e0c-49ea-9c99-1bb7f8f826c5'),PROMPT('quoted:'),HEADER('quoted'),PICTURE(@n3)
[SCREENCONTROLS]
! PROMPT('work:'),USE(?work:Prompt)
! ENTRY(@s200),USE(work)
[REPORTCONTROLS]
! STRING(@s200),USE(work)
work                     STRING(200)
!!> GUID('cb45f0a6-b9cf-4352-adc0-9bf769cb3d29'),PROMPT('work:'),HEADER('work'),PICTURE(@s200)
[SCREENCONTROLS]
! PROMPT('n:'),USE(?n:Prompt)
! ENTRY(@n-14),USE(n),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(n),RIGHT(1)
n                        LONG
!!> GUID('82b76f62-06c0-4f5e-8141-2eb00fac112a'),PROMPT('n:'),HEADER('n'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  skipbl(buf, i)
  quoted = False

  argtype = buf[i]
  IF (argtype = '"'); i += 1; quoted = TRUE.

  n = 1
  work = '';
  skipbl(buf,i)
  LOOP
    argtype = buf[i]
    IF (argtype = '"' AND quoted) OR (buf[i] = CHR(G:Blank) AND ~quoted) |
                      OR buf[i] = CHR(G:newline) OR buf[i] = CHR(G:endstr); BREAK.

    work[n] = buf[i]
    n += 1
    i += 1
  END

  LOOP NN# = 1 to n-1
    arg[NN#] = work[NN#]
  END

[END]
[END]
[PROCEDURE]
NAME checkvar
PROTOTYPE '(*STRING)'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'check  buffer for variable keywords'
FROM Clarion Source
MODIFIED '2026/06/14' '10:48:00'
[DATA]
[SCREENCONTROLS]
! PROMPT('wbuf:'),USE(?wbuf:Prompt)
! TEXT,USE(wbuf)
[REPORTCONTROLS]
! TEXT,USE(wbuf)
wbuf                     STRING(4000)
!!> GUID('dd8f0b5c-4012-4b99-b376-759499c5ac04'),PROMPT('wbuf:'),HEADER('wbuf'),PICTURE(@s255)
[SCREENCONTROLS]
! PROMPT('i:'),USE(?i:Prompt)
! ENTRY(@n-14),USE(i),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(i),RIGHT(1)
i                        LONG
!!> GUID('b05beb82-daa2-4065-85cc-b7483ddbf7a7'),PROMPT('i:'),HEADER('i'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('j:'),USE(?j:Prompt)
! ENTRY(@n-14),USE(j),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(j),RIGHT(1)
j                        LONG
!!> GUID('d41a69ea-81b6-4078-863e-2b434f21c70f'),PROMPT('j:'),HEADER('j'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('x:'),USE(?x:Prompt)
! ENTRY(@n-14),USE(x),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(x),RIGHT(1)
x                        LONG
!!> GUID('283c9f92-5360-4cb7-9114-9d1748c96a1e'),PROMPT('x:'),HEADER('x'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('rep Lng:'),USE(?repLng:Prompt)
! ENTRY(@n-14),USE(repLng),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(repLng),RIGHT(1)
repLng                   LONG
!!> GUID('1613004c-97b7-41aa-bba4-7d8c0e612078'),PROMPT('rep Lng:'),HEADER('rep Lng'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('var Found:'),USE(?varFound:Prompt)
! ENTRY(@n3),USE(varFound)
[REPORTCONTROLS]
! STRING(@n3),USE(varFound)
varFound                 BYTE
!!> GUID('855aa62e-d594-45ad-9ca6-6187954a0b37'),PROMPT('var Found:'),HEADER('var Found'),PICTURE(@n3)
[SCREENCONTROLS]
! PROMPT('var Str:'),USE(?varStr:Prompt)
! ENTRY(@s50),USE(varStr)
[REPORTCONTROLS]
! STRING(@s50),USE(varStr)
varStr                   STRING(50)
!!> GUID('51165b5e-32a2-4764-bf1a-1ec57f9d6368'),PROMPT('var Str:'),HEADER('var Str'),PICTURE(@s50)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
 varFound = False
 i = 1
 j = 1
 LOOP WHILE(buf[i] <> CHR(G:endstr))
    IF buf[i] = '<<'
      x = INSTRING('>', buf, 1, i)

      IF ((x-1) - (i+1)) > 50; x = 0.        ! variable string too big

      IF x <> 0
         VarStr = buf[i+1 : x-1]
        TxtFormQ:VariableStr = CLIP(LOWER(VarStr))
        GET(TxtFormQ, +TxtFormQ:VariableStr)
        IF ERRORCODE() = 30
          wbuf[j] = buf[i]
          i += 1
          j += 1
        ELSE
          varFound = True
          i = x + 1
          repLng = LEN(CLIP(TxtFormQ:ReplaceStr))
          LOOP N# = 1 to repLng
            wbuf[j] = TxtFormQ:ReplaceStr[N#]
            j  += 1
          END
        END  ! ERROCODE() = 30
      ELSE ! closing '>' not found
        wbuf[j] = buf[i]
        i += 1
        j += 1
      END
    ELSE ! no opening '<' found
      wbuf[j] = buf[i]
      i += 1
      j += 1
    END
 END
 IF varFound
   wbuf[j] = CHR(G:endstr)
   scopy(wbuf, 1, buf, 1)
 END


[END]
[END]
[END]
