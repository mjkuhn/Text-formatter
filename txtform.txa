!!> GUID('e983e854-b235-455c-a934-03eed176a2f2'),PROMPT('cmd:'),HEADER('cmd'),PICTURE(@s2)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  cmd = LOWER(buf[2 : 3])
  CASE cmd
    OF 'fi'
      cmdval = fi
    OF 'nf'
      cmdval = nf
    OF 'ju'
      cmdval = ju
    OF 'nj'
      cmdval = nj
    OF 'br'
      cmdval = br
    OF 'ls'
      cmdval = ls
    OF 'rm'
      cmdval = rm
    OF 'lm'
      cmdval = lm
    OF 'ti'
      cmdval = ti
    OF 'sp'
      cmdval = sp
    OF 'bp'
      cmdval = bp
    OF 'pc'
      cmdval = pc
    OF 'ta'
      cmdval = ta
    OF 'ce'
      cmdval = ce
    OF 'ul'
      cmdval = ul
    OF 'bf'
      cmdval = bf
    OF 'he'
      cmdval = he
    OF 'fo'
      cmdval = fo
    OF 'pl'
      cmdval = pl
    OF 'vm'
      cmdval = vm
    OF 'ac'
      cmdval = ac
    OF 'in'
      cmdval = inc
    OF 'da'
      cmdval = da
    OF 'dn'
      cmdval = dn
    OF 'ke'
      cmdval = ke
    OF 'ne'
      cmdval = ne
    OF 'pd'
      cmdval = pd
    OF 'pi'
      cmdval = pi
    OF 'qu'
      cmdval = qu
    OF 'qd'
