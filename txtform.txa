[PROCEDURE]
NAME spread
PROTOTYPE '(*STRING,LONG,LONG,LONG)'
PARAMETERS '(buf,outp,nextra,outwds)'
NOEXPORT
[COMMON]
DESCRIPTION 'spreads words between the margins'
FROM Clarion Source
MODIFIED '2026/06/14' '10:44:57'
[DATA]
[SCREENCONTROLS]
! PROMPT('i:'),USE(?i:Prompt)
! ENTRY(@n-14),USE(i),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(i),RIGHT(1)
i                        LONG
!!> GUID('55bf409b-4be5-4fcd-bd6a-177ccaf96bad'),PROMPT('i:'),HEADER('i'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('j:'),USE(?j:Prompt)
! ENTRY(@n-14),USE(j),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(j),RIGHT(1)
j                        LONG
!!> GUID('1e9d80d3-e8ee-46c9-ae9d-b9b59759aaf1'),PROMPT('j:'),HEADER('j'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('nb:'),USE(?nb:Prompt)
! ENTRY(@n-14),USE(nb),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(nb),RIGHT(1)
nb                       LONG
!!> GUID('2b363593-0532-4519-90c4-9ae0791c2b1a'),PROMPT('nb:'),HEADER('nb'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('nholes:'),USE(?nholes:Prompt)
! ENTRY(@n-14),USE(nholes),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(nholes),RIGHT(1)
nholes                   LONG
!!> GUID('c9221ac3-a840-4c32-acd1-66ec4f9e2e14'),PROMPT('nholes:'),HEADER('nholes'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  IF (nextra > 0) AND (outwds > 1)
    G:dir = 1 - G:dir                 !reverse direction
    nholes = outwds -1
    i = outp - 1
    j = min(G:maxstr-2, i+nextra)     !room for newline and endstr

    LOOP WHILE(i < j)
      buf[j] = buf[i]

      IF buf[i] = CHR(G:blank)
        IF G:dir = 0
          nb = (nextra - 1) / nholes + 1
        ELSE
          nb = nextra / nholes
        END

        nextra = nextra - nb
        nholes = nholes -1

        LOOP WHILE(nb > 0)
          j -= 1
          buf[j] = CHR(G:blank)
          nb -= 1
        END
      END

      i -= 1
      j -= 1
    END
  END

[END]
[END]
[PROCEDURE]
NAME putword
PROTOTYPE '(*STRING)'
PARAMETERS '(wordbuf)'
NOEXPORT
[COMMON]
DESCRIPTION 'moves words into output buffer'
FROM Clarion Source
MODIFIED '2026/06/14' '10:45:09'
[DATA]
[SCREENCONTROLS]
! PROMPT('last:'),USE(?last:Prompt)
! ENTRY(@n-14),USE(last),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(last),RIGHT(1)
last                     LONG
!!> GUID('98d5c055-bf00-4fcd-b755-f17c65779a4f'),PROMPT('last:'),HEADER('last'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('llval:'),USE(?llval:Prompt)
! ENTRY(@n-14),USE(llval),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(llval),RIGHT(1)
llval                    LONG
!!> GUID('8d3c4598-90ce-40e8-84da-e2d6cca09ace'),PROMPT('llval:'),HEADER('llval'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('nextra:'),USE(?nextra:Prompt)
! ENTRY(@n-14),USE(nextra),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(nextra),RIGHT(1)
nextra                   LONG
!!> GUID('8878f77d-3475-4979-b058-6e95d1184ed5'),PROMPT('nextra:'),HEADER('nextra'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('w:'),USE(?w:Prompt)
! ENTRY(@n-14),USE(w),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(w),RIGHT(1)
w                        LONG
!!> GUID('a5b55c90-95d4-4574-8c73-3e5c0c957b39'),PROMPT('w:'),HEADER('w'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  w = fwidth(wordbuf)
  last = flength(wordbuf) + G:outp + 1   !new end of outbuf
  llval = G:rmval - G:tival - G:inval

  IF (G:outp > 0) AND ((G:outw+w > llval) OR (last >= G:maxstr))
    last = last - G:outp           !remember end of wordbuf

    IF G:justify
      nextra = llval - G:outw + 1
      IF (nextra > 0) AND (G:outwds > 1)
        spread(G:outbuf, G:outp, nextra, G:outwds)
        G:outp = G:outp + nextra
      END
    END

    dobreak          ! flush previous line
  END

  scopy(wordbuf, 1, G:outbuf, G:outp+1)

  G:outp = last
  G:outbuf[G:outp] = CHR(G:blank)     !blank between words
  G:outw   = G:outw + w + 1           !1 for blank
  G:outwds = G:outwds + 1

[END]
[END]
[PROCEDURE]
NAME fwidth
PROTOTYPE '(*STRING)LONG'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'return width of buffer, newline has a width of zero'
FROM Clarion Source
MODIFIED '2026/06/14' '10:45:21'
[DATA]
[SCREENCONTROLS]
! PROMPT('i:'),USE(?i:Prompt)
! ENTRY(@n-14),USE(i),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(i),RIGHT(1)
i                        LONG
!!> GUID('cbb874bd-3d56-4038-8793-4c18d7aa8d26'),PROMPT('i:'),HEADER('i'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('w:'),USE(?w:Prompt)
! ENTRY(@n-14),USE(w),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(w),RIGHT(1)
w                        LONG
!!> GUID('d8958a57-7afd-40ab-b58c-389a827dfac7'),PROMPT('w:'),HEADER('w'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  w = 0
  i = 1

  LOOP WHILE(buf[i] <> CHR(G:endstr))
    IF buf[i] = CHR(G:backspace)
      w -= 1
    ELSIF buf[i] = CHR(G:newline)
    ELSE
      w += 1
    END

    i += 1
  END

  RETURN(w)


[END]
[END]
[PROCEDURE]
NAME flength
PROTOTYPE '(*STRING)LONG'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'return length of string, excluding the endstr'
FROM Clarion Source
MODIFIED '2026/06/14' '10:45:30'
[DATA]
[SCREENCONTROLS]
! PROMPT('n:'),USE(?n:Prompt)
! ENTRY(@n-14),USE(n),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(n),RIGHT(1)
n                        LONG
!!> GUID('48aab8c0-d97b-4073-ad0d-9828f658e71f'),PROMPT('n:'),HEADER('n'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  n = 1
  LOOP WHILE(buf[n] <> CHR(G:endstr))
    n += 1
  END
  RETURN(n-1)
[END]
[END]
[PROCEDURE]
NAME space
PROTOTYPE '(LONG)'
PARAMETERS '(n)'
NOEXPORT
[COMMON]
DESCRIPTION 'skips N lines to the bottom of page'
FROM Clarion Source
MODIFIED '2026/06/14' '10:45:41'
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  dobreak
  IF G:lineno <= G:bottom
    IF G:lineno <= 0; puthead.

    doskip(min(n, G:bottom+1-G:lineno))
    G:lineno += n

    IF G:lineno > G:bottom; putfoot.
  END
[END]
[END]
