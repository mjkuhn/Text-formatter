[PROCEDURE]
NAME skipbl
PROTOTYPE '(*STRING, *LONG)'
PARAMETERS '(buf, i)'
NOEXPORT
[COMMON]
DESCRIPTION 'skip spaces'
FROM Clarion Source
MODIFIED '2026/06/14' '10:43:48'
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LOOP WHILE(buf[i] = CHR(G:blank))
  i += 1
END
