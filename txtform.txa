[PROCEDURE]
NAME getword
PROTOTYPE '(*STRING,LONG,*STRING,*LONG) '
PARAMETERS '(buf,i,bufout,ptr)'
NOEXPORT
[COMMON]
DESCRIPTION 'gets one word from buffer and moves it out'
FROM Clarion Source
MODIFIED '2026/06/14' '10:46:14'
[DATA]
[SCREENCONTROLS]
! PROMPT('j:'),USE(?j:Prompt)
! ENTRY(@n-14),USE(j),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(j),RIGHT(1)
j                        LONG
!!> GUID('2d84ed38-f9b2-483e-ab52-a18839947784'),PROMPT('j:'),HEADER('j'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  LOOP WHILE(buf[i] = CHR(G:blank) OR buf[i] = CHR(G:newline))
    i += 1
  END
  j += 1

  LOOP WHILE (buf[i] <> CHR(G:endstr) AND buf[i] <> CHR(G:blank) AND buf[i] <> CHR(G:newline))
    bufout[j] = buf[i]
    i += 1
    j += 1
  END

  bufout[j] = CHR(G:endstr)
  IF buf[i] = CHR(G:endstr)
    ptr = 0
  ELSE
    ptr = i
  END
[END]
[END]
[PROCEDURE]
NAME dobreak
NOEXPORT
[COMMON]
DESCRIPTION 'clears output buffer by outputting line'
FROM Clarion Source
MODIFIED '2026/06/14' '10:46:25'
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  IF G:outp > 0
    G:outbuf[G:outp]   = CHR(G:newline)
    G:outbuf[G:outp+1] = CHR(G:endstr)
    doput(G:outbuf)
  END
  G:outp   = 0
  G:outw   = 0
  G:outwds = 0
[END]
[END]
[PROCEDURE]
NAME scopy
PROTOTYPE '(*STRING,LONG,*STRING,LONG)'
PARAMETERS '(str,i,dest,j)'
NOEXPORT
[COMMON]
DESCRIPTION 'copy a string, terminated by endstr'
FROM Clarion Source
MODIFIED '2026/06/14' '10:46:38'
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  LOOP WHILE(str[i] <> CHR(G:endstr))
    dest[j] = str[i]
    i += 1
    j += 1
  END
  dest[j] = CHR(G:endstr)
[END]
[END]
[PROCEDURE]
NAME doskip
PROTOTYPE '(LONG)'
PARAMETERS '(n)'
NOEXPORT
[COMMON]
DESCRIPTION 'skip N number of lines'
FROM Clarion Source
MODIFIED '2026/06/14' '10:46:47'
[DATA]
[SCREENCONTROLS]
! PROMPT('x:'),USE(?x:Prompt)
! ENTRY(@n-14),USE(x),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(x),RIGHT(1)
x                        LONG
!!> GUID('fb1fa413-64fe-40df-8006-dc8c2a5dd98b'),PROMPT('x:'),HEADER('x'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  LOOP x = 1 to n
    WriteTextBuffer(CHR(G:CR))
    WriteTextBuffer(CHR(G:LF))
  END
[END]
[END]
[PROCEDURE]
NAME doput
PROTOTYPE '(*STRING)'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'put out line with spacing and indents'
FROM Clarion Source
MODIFIED '2026/06/14' '10:47:00'
[DATA]
[SCREENCONTROLS]
! PROMPT('n:'),USE(?n:Prompt)
! ENTRY(@n-14),USE(n),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(n),RIGHT(1)
n                        LONG
!!> GUID('cacf1eba-ef9c-4092-8f00-1bfa2576665e'),PROMPT('n:'),HEADER('n'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('x:'),USE(?x:Prompt)
! ENTRY(@n-14),USE(x),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(x),RIGHT(1)
x                        LONG
!!> GUID('470b639d-8fc8-4961-a3f6-299e25faa383'),PROMPT('x:'),HEADER('x'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  LOOP x = 1 TO (G:inval+G:tival)
    WriteTextBuffer(CHR(G:blank))
  END

  n = 1
  LOOP WHILE(buf[n] <> CHR(G:endstr))

    IF buf[n] = CHR(G:newline)
      WriteTextBuffer(CHR(G:CR))
      WriteTextBuffer(CHR(G:LF))
    ELSIF buf[n] = CHR(G:hardspace)
      WriteTextBuffer(CHR(G:blank))
    ELSE
      WriteTextBuffer(buf[n])
    END

    n += 1
  END

  G:tival = 0
  doskip(min(G:lsval-1, G:bottom-G:lineno))
  G:lineno += G:lsval
  IF G:lineno > G:bottom; putfoot.




[END]
[END]
[PROCEDURE]
NAME writetextbuffer
PROTOTYPE '(STRING)'
PARAMETERS '(strchr)'
NOEXPORT
