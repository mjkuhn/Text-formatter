[PROCEDURE]
NAME getval
PROTOTYPE '(*STRING,*BYTE,*LONG,*LONG)'
PARAMETERS '(buf, argtype, arg, i)'
NOEXPORT
[COMMON]
DESCRIPTION 'gets the numeric argument on command line'
FROM Clarion Source
MODIFIED '2026/06/14' '10:43:58'
[DATA]
[SCREENCONTROLS]
! PROMPT('work:'),USE(?work:Prompt)
! ENTRY(@s5),USE(work)
[REPORTCONTROLS]
! STRING(@s5),USE(work)
work                     STRING(5)
!!> GUID('a04c36ec-41fe-4ed0-93d7-f77cd770efba'),PROMPT('work:'),HEADER('work'),PICTURE(@s5)
[SCREENCONTROLS]
! PROMPT('n:'),USE(?n:Prompt)
! ENTRY(@n-14),USE(n),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(n),RIGHT(1)
n                        LONG
!!> GUID('8b6b509f-46fe-4f41-bc93-813d2ec6c3d3'),PROMPT('n:'),HEADER('n'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  skipbl(buf, i)

  argtype = buf[i]
  IF (argtype = CHR(G:plus)) OR (argtype = CHR(G:minus)); i =+ 1.

  n = 1
  work = '';
  skipbl(buf,i)
  LOOP
    IF buf[i] = CHR(G:blank) OR buf[i] = CHR(G:newline) OR buf[i] = CHR(G:endstr); BREAK.

    work[n] = buf[i]
    n += 1
    i += 1
  END

  IF ~NUMERIC(work)
    arg = 0
  ELSE
    arg = work
  END
[END]
[END]
[PROCEDURE]
NAME docommand
PROTOTYPE '(*STRING)'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'process the dot command'
FROM Clarion Source
MODIFIED '2026/06/14' '10:44:10'
[DATA]
[SCREENCONTROLS]
! PROMPT('cmd:'),USE(?cmd:Prompt)
! ENTRY(@n3),USE(cmd)
[REPORTCONTROLS]
! STRING(@n3),USE(cmd)
cmd                      BYTE
!!> GUID('7ff500a8-7f94-489f-b2f5-a52ba4157735'),PROMPT('cmd:'),HEADER('cmd'),PICTURE(@n3)
[SCREENCONTROLS]
! PROMPT('cmdval:'),USE(?cmdval:Prompt)
! ENTRY(@n-14),USE(cmdval),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(cmdval),RIGHT(1)
cmdval                   LONG
!!> GUID('7636d746-5284-4f0d-b9c6-d828181ae6fc'),PROMPT('cmdval:'),HEADER('cmdval'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('argtype:'),USE(?argtype:Prompt)
! ENTRY(@n3),USE(argtype)
[REPORTCONTROLS]
! STRING(@n3),USE(argtype)
argtype                  BYTE
!!> GUID('971796ab-7a32-456d-90ed-91708ab64cc4'),PROMPT('argtype:'),HEADER('argtype'),PICTURE(@n3)
[SCREENCONTROLS]
! PROMPT('spval:'),USE(?spval:Prompt)
! ENTRY(@n-14),USE(spval),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(spval),RIGHT(1)
spval                    LONG
!!> GUID('2bcb242b-1bc4-4ce8-b442-aac337f44723'),PROMPT('spval:'),HEADER('spval'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('x:'),USE(?x:Prompt)
! ENTRY(@n-14),USE(x),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(x),RIGHT(1)
x                        LONG
!!> GUID('19e0c59e-850a-4457-a28a-c7bcb342b5ec'),PROMPT('x:'),HEADER('x'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[SCREENCONTROLS]
! PROMPT('Var Str:'),USE(?VarStr:Prompt)
! ENTRY(@s200),USE(VarStr)
[REPORTCONTROLS]
! STRING(@s200),USE(VarStr)
VarStr                   STRING(200)
!!> GUID('18b32716-80bd-4e90-b885-7d8e2b613d6e'),PROMPT('Var Str:'),HEADER('Var Str'),PICTURE(@s200)
[SCREENCONTROLS]
! PROMPT('Rep Str:'),USE(?RepStr:Prompt)
! ENTRY(@s200),USE(RepStr)
[REPORTCONTROLS]
! STRING(@s200),USE(RepStr)
RepStr                   STRING(200)
!!> GUID('1a66adb8-64bb-4475-83fe-424d4ab8145b'),PROMPT('Rep Str:'),HEADER('Rep Str'),PICTURE(@s200)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
 cmd = getcmd(buf)

 x = 4
 IF cmd <> unknown; getval(buf, argtype, cmdval, x).

 CASE cmd
   OF sp
     space(max(cmdval,1))
   OF br
     dobreak
   OF fi
     dobreak
     G:fill = TRUE
   OF nf
     dobreak
     G:fill = FALSE
   OF ju
     dobreak
     G:justify = TRUE
   OF nj
     dobreak
     G:justify = FALSE
   OF ls
     setparm(G:lsval, cmdval, argtype, 1, 1, G:huge)
   OF rm
     setparm(G:rmval, cmdval, argtype, G:pagewidth, G:inval+G:tival+1, G:huge)
   OF lm
     dobreak
     setparm(G:inval, cmdval, argtype, 0, 0, G:rmval-1)
   OF ce
     dobreak
     setparm(G:ceval, cmdval, argtype, 1, 0, G:huge)
   OF ti
     dobreak
     setparm(G:tival, cmdval, argtype, 0, -G:huge, G:rmval)
   OF qu
     x = 4
     getstrn(buf, VarStr, x)
     getstrn(buf, RepStr, x)

     TxtFormQ:VariableStr = CLIP(LOWER(VarStr))
     GET(TxtFormQ, +TxtFormQ:VariableStr)
     IF ERRORCODE() = 30
       TxtFormQ:VariableStr = CLIP(LOWER(VarStr))
       TxtFormQ:ReplaceStr  = CLIP(RepStr)
       ADD(TxtFormQ, +TxtFormQ:VariableStr)
     END

    OF qd
      TxtFormQNbr# = RECORDS(TxtFormQ)
      LOOP II# = 1 to TxtFormQNbr#
        GET(TxtFormQ, II#)

        G:inbuf = '(' & CLIP(TxtFormQ:VariableStr) & ':' & CLIP(TxtFormQ:ReplaceStr) & ')'
        LNG# = LEN(CLIP(G:Inbuf))
        G:inbuf[LNG#+1] = CHR(G:newline)
        G:inbuf[LNG#+2] = CHR(G:endstr)
        textout(G:inbuf)
      END
 END

[END]
[END]
[PROCEDURE]
NAME textout
PROTOTYPE '(*STRING)'
PARAMETERS '(inbuf)'
NOEXPORT
[COMMON]
DESCRIPTION 'process in buffer to output buffer'
FROM Clarion Source
MODIFIED '2026/06/14' '10:44:21'
[DATA]
[SCREENCONTROLS]
! PROMPT('wordbuf:'),USE(?wordbuf:Prompt)
! TEXT,USE(wordbuf)
[REPORTCONTROLS]
! TEXT,USE(wordbuf)
wordbuf                  STRING(400)
!!> GUID('f322c87a-afbd-4a18-949b-b0ed7cd66ce2'),PROMPT('wordbuf:'),HEADER('wordbuf'),PICTURE(@s255)
[SCREENCONTROLS]
! PROMPT('i:'),USE(?i:Prompt)
! ENTRY(@n-14),USE(i),RIGHT(1)
[REPORTCONTROLS]
! STRING(@n-14),USE(i),RIGHT(1)
i                        LONG
!!> GUID('8e75ad29-9a10-4522-9b63-6aab271f8f55'),PROMPT('i:'),HEADER('i'),PICTURE(@n-14),JUSTIFY(RIGHT,1)
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  IF (inbuf[1] = CHR(G:blank)) OR (inbuf[1] = CHR(G:newline)); leadbl(inbuf).

  IF RECORDS(TxtFormQ) > 0
    checkvar(inbuf)                  ! check for variable substitution
  END

  IF G:ceval > 0
    docenter(inbuf)
    doput(inbuf)
    G:ceval -= 1
  ELSIF inbuf[1] = CHR(G:newline)
      doput(inbuf)                  !blank line
  ELSIF ~G:fill
      doput(inbuf)                  !unfilled text
  ELSE
      i = 1
      LOOP UNTIL(i = 0)
        getword(inbuf, i, wordbuf, i)
        IF i > 0; putword(wordbuf).
      END
  END
[END]
[END]
[PROCEDURE]
NAME setparm
PROTOTYPE '(*LONG,*LONG,BYTE,LONG,LONG,LONG)'
PARAMETERS '(param,theval,argtype,defval,minval,maxval)'
NOEXPORT
[COMMON]
DESCRIPTION 'sets variable to numeric argument'
FROM Clarion Source
MODIFIED '2026/06/14' '10:44:32'
[PROMPTS]
%GenerateOpenClose LONG  (0)
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  IF argtype = G:newline
    param = defval
  ELSIF argtype = G:plus
    param += theval
  ELSIF argtype = G:minus
    param -= theval
  ELSE
     param = theval
  END

  param = min(param, maxval)
  param = max(param, minval)

 
[END]
[END]
[PROCEDURE]
NAME getcmd
PROTOTYPE '(*STRING)BYTE'
PARAMETERS '(buf)'
NOEXPORT
[COMMON]
DESCRIPTION 'convert the dot command to numeric value'
FROM Clarion Source
MODIFIED '2026/06/14' '10:44:46'
[DATA]
